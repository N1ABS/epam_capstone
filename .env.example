# ─── LLM Providers ───────────────────────────────────────────────────────────
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama (optional local fallback — zero cost, fully offline) — run: `ollama pull llama3.2`
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# ─── Web Search via MCP ───────────────────────────────────────────────────────
# Tavily — free tier (100 req/mo): https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Observability ────────────────────────────────────────────────────────────
# LangSmith — free tier: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=personal-knowledge-assistant

# ─── Vector Database ──────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_base

# ─── RAG Settings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_DOCUMENTS=5
# Confidence below this threshold triggers web search fallback
CONFIDENCE_THRESHOLD=0.6
MAX_WEB_RESULTS=5

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum requests per user per window (default: 10 per 60 seconds)
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Authentication ───────────────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require login before accessing the UI
AUTH_ENABLED=false
AUTH_USERNAME=admin
# Generate hash: python -c "import hashlib; print(hashlib.sha256(b'yourpassword').hexdigest())"
AUTH_PASSWORD_HASH=e3c652f0ba0b4801205814f8b6bc49672c4c74e25b497770bb89b22cdeb4e951

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
# Set OTEL_CONSOLE_EXPORT=true to print spans to stdout (local debugging)
OTEL_CONSOLE_EXPORT=false
# Set OTEL_EXPORTER_OTLP_ENDPOINT for a collector (Jaeger, Tempo, Honeycomb, etc.)
# Requires: pip install opentelemetry-exporter-otlp-proto-grpc
OTEL_EXPORTER_OTLP_ENDPOINT=
